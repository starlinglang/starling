{
  "plugins": [],
  "recurseDepth": 10,
  "source": {
    "include": [
      "README.md",
      "lang/grammar.js",
      "lang/mmgen.js",
      "lang/syntaxtree.js",
      "lang/compiler.js"
    ],
    "includePattern": ".+\\.js(doc|x)?$",
    "excludePattern": "(^|\\/|\\\\)_"
  },
  "sourceType": "module",
  "tags": {
    "allowUnknownTags": true,
    "dictionaries": ["jsdoc", "closure"]
  },
  "templates": {
    "cleverLinks": false,
    "monospaceLinks": false
  }
}
