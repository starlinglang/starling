{
  "name": "starling",
  "version": "0.0.1",
  "description": "Starling language.",
  "license": "MIT",
  "author": "enderverse",
  "repository": "github.com/starlinglang/starling",
  "type": "module",
  "source": "lang/index.js",
  "browser": "ide/editor/lang.mjs",
  "scripts": {
    "start": "node lang/index.js",
    "lint": "npx standard --fix && npx htmlhint 'ide/editor/*.html' 'ide/index.html'",
    "test": "npx vitest",
    "build": "parcel build &&  npx jsdoc -c jsdoc.json -d ide/docs",
    "build:lang": "parcel build --no-content-hash --target browser --no-source-maps",
    "build:docs": "npx jsdoc -c jsdoc.json -d ide/docs",
    "watch": "parcel watch"
  },
  "dependencies": {
    "ohm-js": "^17.5.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "htmlhint": "^1.9.2",
    "jsdoc": "^4.0.5",
    "parcel": "^2.16.4",
    "standard": "^17.1.2",
    "vitest": "^4.1.4"
  },
  "standard": {
    "ignore": [
      "ide/analytics.js",
      "ide/docs/scripts",
      "ide/editor/src/lang.mjs"
    ]
  },
  "release": {
    "branches": [
      "main"
    ]
  },
  "targets": {
    "browser": {
      "includeNodeModules": [
        "ohm-js"
      ]
    }
  }
}
